{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd src/apps/web && npx vite build",
  "outputDirectory": "src/apps/web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://trade-api.onrender.com/api/$1"
    },
    {
      "source": "/ws",
      "destination": "wss://trade-api.onrender.com/ws"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://trade-api.onrender.com",
    "VITE_API_WS_URL": "wss://trade-api.onrender.com",
    "VITE_CLERK_PUBLISHABLE_KEY": "pk_test_cHJvZm91bmQtcmVpbmRlZXItMzIuY2xlcmsuYWNjb3VudHMuZGV2JA"
  }
}
