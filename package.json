{
  "name": "crypto-trading-bot-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/packages/*",
    "src/apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:with-db": "./scripts/test-with-db.sh",
    "test:db:start": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:stop": "docker-compose -f docker-compose.test.yml down",
    "test:db:clean": "docker-compose -f docker-compose.test.yml down -v",
    "test:e2e": "vitest run -c tests/e2e/vitest.config.e2e.ts",
    "test:e2e:watch": "vitest watch -c tests/e2e/vitest.config.e2e.ts",
    "test:e2e:ci": "vitest run -c tests/e2e/vitest.config.e2e.ts --coverage --reporter=verbose --reporter=json --reporter=html",
    "test:e2e:setup": "docker compose -f tests/e2e/docker-compose.test.yml up -d --build",
    "test:e2e:teardown": "docker compose -f tests/e2e/docker-compose.test.yml down -v",
    "test:e2e:logs": "docker compose -f tests/e2e/docker-compose.test.yml logs -f",
    "test:e2e:status": "docker compose -f tests/e2e/docker-compose.test.yml ps",
    "test:smoke": "npm run typecheck && npm test -- apps/api/src/app.test.ts apps/worker/src/worker.test.ts apps/telegram-bot/src/utils/api.test.ts apps/telegram-bot/src/commands/commands.test.ts apps/telegram-bot/src/utils/formatters.test.ts packages/shared/src/notifications/handlers/websocket-handler.test.ts",
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:telegram": "npm run dev -w apps/telegram-bot",
    "dev:mobile": "npm start -w apps/mobile",
    "typecheck": "tsc -b tsconfig.json",
    "render:build": "npm install && tsc -b --force && ls -la apps/api/dist/ apps/telegram-bot/dist/",
    "render:start": "concurrently --kill-others-on-fail \"npm start -w apps/api\" \"npm start -w apps/telegram-bot\""
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.3.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.2",
    "zod": "^3.24.3"
  }
}
