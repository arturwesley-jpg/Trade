# Complete environment variables template
# Copy to .env and fill in your values

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_ENV=development
APP_MODE=paper
SAFE_MODE=true
PAPER_TRADING_ONLY=true
FEATURE_REAL_TRADING=false
NODE_ENV=development

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=trade_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=trade_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://trade_user:change_me_in_production@localhost:5432/trade_db

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_min_32_chars

# ============================================
# DATA STORAGE
# ============================================
DATA_DIR=./data
TRADE_STORE_PATH=./data/trade-store.json
ADMIN_API_TOKEN=

# ============================================
# MARKET DATA PROVIDERS
# ============================================
MARKET_PROVIDER_PRIMARY=binance
MARKET_PROVIDER_FALLBACK_1=bybit
MARKET_PROVIDER_FALLBACK_2=okx
MARKET_PROVIDER_FALLBACK_3=kraken
MARKET_SYMBOLS=BTC-USDT,ETH-USDT
USE_SIMULATED_MARKET=true
MARKET_REST_PROVIDERS=simulated
MARKET_POLL_INTERVAL_MS=1000
MAX_MARKET_TICKS=1000
PROVIDER_STALE_AFTER_MS=10000

# WebSocket Configuration
BINGX_WS_URL=wss://open-api-swap.bingx.com/swap-market

# ============================================
# EXCHANGE API KEYS (Production)
# ============================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BINGX_API_KEY=
BINGX_API_SECRET=

# ============================================
# DATA PROVIDERS API KEYS
# ============================================
COINGECKO_API_KEY=
CRYPTOCOMPARE_API_KEY=
NEWS_API_KEY=
MESSARI_API_KEY=
GLASSNODE_API_KEY=

# ============================================
# BLOCKCHAIN EXPLORERS
# ============================================
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=

# ============================================
# PAPER TRADING CONFIGURATION
# ============================================
PAPER_MAKER_FEE_PCT=0.075
PAPER_TAKER_FEE_PCT=0.075
PAPER_SLIPPAGE_PCT=0.05

# ============================================
# RISK MANAGEMENT
# ============================================
MAX_POSITIONS=5
MAX_MARGIN_PER_POSITION=100
TOTAL_MARGIN_LIMIT=500
POSITION_MONITOR_ENABLED=true

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ADMIN_IDS=
TELEGRAM_RATE_LIMIT_MAX=20
TELEGRAM_RATE_LIMIT_WINDOW_MS=60000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
GRAFANA_ROOT_URL=http://localhost:3000

# AlertManager
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=
OPSGENIE_API_KEY=

# ============================================
# DOCKER & DEPLOYMENT
# ============================================
REGISTRY=ghcr.io
IMAGE_PREFIX=trade
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=trade

# ============================================
# SECURITY
# ============================================
# JWT & Encryption
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-production
ENCRYPTION_KEY=your-encryption-key-min-32-chars-change-in-production
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key-min-32-chars-change-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# Security Features
HELMET_ENABLED=true
CSRF_ENABLED=true
ENABLE_IP_WHITELIST=false
ADMIN_IP_WHITELIST=127.0.0.1,::1
ENABLE_BRUTE_FORCE_PROTECTION=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000
ENABLE_2FA=true
ENABLE_API_KEY_AUTH=true
ENABLE_AUDIT_LOGGING=true

# Database Security
DATABASE_SSL=false

# 2FA Configuration
TWO_FACTOR_ISSUER=TradingPlatform

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================
# EMAIL (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@tradingbot.com

# ============================================
# BACKUP & RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_SENTIMENT_ANALYSIS=true
FEATURE_ML_PREDICTIONS=false
FEATURE_DEFI_INTEGRATION=false
FEATURE_ADVANCED_CHARTS=true
FEATURE_SOCIAL_TRADING=false

# ============================================
# PERFORMANCE TUNING
# ============================================
NODE_OPTIONS=--max-old-space-size=4096
UV_THREADPOOL_SIZE=128
WORKER_THREADS=4

# ============================================
# DEVELOPMENT TOOLS
# ============================================
DEBUG=false
MOCK_EXCHANGES=false
ENABLE_PROFILING=false
ENABLE_TRACING=false
