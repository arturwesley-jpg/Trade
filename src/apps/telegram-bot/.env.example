# Telegram Bot Configuration

# Required: Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required in production: Comma-separated list of allowed Telegram user IDs
# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Optional: Admin user IDs (subset of allowed users with admin privileges)
TELEGRAM_ADMIN_IDS=123456789

# API Configuration
API_BASE_URL=http://localhost:4000

# Environment (development or production)
APP_ENV=development

# Rate Limiting
TELEGRAM_RATE_LIMIT_MAX=20
TELEGRAM_RATE_LIMIT_WINDOW_MS=60000
