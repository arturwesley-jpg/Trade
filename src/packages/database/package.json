{
  "name": "@trading-bot/database",
  "version": "1.0.0",
  "description": "Database layer for Trading Bot",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
